<!DOCTYPE html>
<html lang="fr" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hub Calculators - Kingshot</title>
    <style>
        :root {
            --bg-dark: #121212;
            --bg-panel: #1e1e1e;
            --text-light: #e0e0e0;
            --accent: #bb86fc;
            --border: #333;
        }
        [data-theme="light"] {
            --bg-dark: #f0f2f5;
            --bg-panel: #ffffff;
            --text-light: #333333;
            --accent: #6200ee;
            --border: #dddddd;
        }
        body {
            margin: 0;
            padding: 0;
            height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-dark);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            transition: background-color 0.3s;
        }
        .header {
            display: flex;
            align-items: center;
            background-color: var(--bg-panel);
            padding: 10px 20px;
            border-bottom: 1px solid var(--border);
            gap: 15px;
            z-index: 10;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        }
        .header h1 {
            margin: 0;
            font-size: 18px;
            color: var(--accent);
            margin-right: 15px;
        }
        .tab-btn {
            background-color: transparent;
            color: var(--text-light);
            border: 1px solid var(--border);
            padding: 8px 16px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            font-weight: bold;
            transition: all 0.2s;
        }
        .tab-btn:hover {
            background-color: rgba(187, 134, 252, 0.1);
            border-color: var(--accent);
        }
        .tab-btn.active {
            background-color: var(--accent);
            color: #fff;
            border-color: var(--accent);
        }
        .theme-toggle {
            margin-left: auto;
            background: var(--bg-dark);
            color: var(--text-light);
            border: 1px solid var(--border);
            padding: 6px 12px;
            border-radius: 20px;
            cursor: pointer;
            font-size: 13px;
            font-weight: bold;
            transition: all 0.2s;
        }
        .frame-container {
            flex: 1;
            position: relative;
        }
        iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: none;
            display: none;
            background-color: transparent;
        }
        iframe.active {
            display: block;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>🛠️ Hub Calculators</h1>
        <button class="tab-btn active" onclick="switchTab(0)">Research Calculator</button>
        <button class="tab-btn" onclick="switchTab(1)">TrueGold Calculator</button>
        <button class="theme-toggle" id="main-theme-toggle" onclick="toggleMainTheme()">☀️ Light Mode</button>
    </div>

    <div class="frame-container">
        <iframe id="frame-0" class="active"></iframe>
        <iframe id="frame-1"></iframe>
    </div>

    <script>
        const resData = "";
        const tgData = "";

        function decodeUTF8Base64(b64) {
            const binString = window.atob(b64);
            const bytes = new Uint8Array(binString.length);
            for (let i = 0; i < binString.length; i++) {
                bytes[i] = binString.charCodeAt(i);
            }
            return new TextDecoder('utf-8').decode(bytes);
        }

        function loadIframe(index, b64Data) {
            try {
                const iframe = document.getElementById('frame-' + index);
                const htmlContent = decodeUTF8Base64(b64Data);
                
                const doc = iframe.contentWindow.document;
                doc.open();
                doc.write(htmlContent);
                doc.close();
            } catch (e) {
                console.error("Erreur au chargement de l'iframe " + index, e);
            }
        }

        function switchTab(index) {
            document.querySelectorAll('.tab-btn').forEach((btn, i) => {
                if (i === index) btn.classList.add('active');
                else btn.classList.remove('active');
            });
            document.querySelectorAll('iframe').forEach((iframe, i) => {
                if (i === index) iframe.classList.add('active');
                else iframe.classList.remove('active');
            });
        }

        function initMainTheme() {
            const savedTheme = localStorage.getItem('hub_calc_theme') || 'dark';
            document.documentElement.setAttribute('data-theme', savedTheme);
            updateMainThemeButton(savedTheme);
            
            localStorage.setItem('tg_calc_theme', savedTheme);
            localStorage.setItem('research_calc_theme', savedTheme);
        }

        function toggleMainTheme() {
            const current = document.documentElement.getAttribute('data-theme');
            const target = current === 'dark' ? 'light' : 'dark';
            
            document.documentElement.setAttribute('data-theme', target);
            localStorage.setItem('hub_calc_theme', target);
            localStorage.setItem('tg_calc_theme', target);
            localStorage.setItem('research_calc_theme', target);
            
            updateMainThemeButton(target);
            syncIframesTheme(target);
        }

        function updateMainThemeButton(theme) {
            const btn = document.getElementById('main-theme-toggle');
            if (theme === 'dark') {
                btn.textContent = '☀️ Light Mode';
                btn.style.background = '#333';
                btn.style.color = '#fff';
            } else {
                btn.textContent = '🌙 Dark Mode';
                btn.style.background = '#fff';
                btn.style.color = '#333';
            }
        }

        function syncIframesTheme(theme) {
            [0, 1].forEach(index => {
                try {
                    const iframe = document.getElementById('frame-' + index);
                    if (iframe && iframe.contentWindow && iframe.contentWindow.document) {
                        iframe.contentWindow.document.documentElement.setAttribute('data-theme', theme);
                    }
                } catch(e) {}
            });
        }

        window.onload = () => {
            initMainTheme();
            loadIframe(0, resData);
            loadIframe(1, tgData);
            
            setTimeout(() => {
                const theme = document.documentElement.getAttribute('data-theme');
                syncIframesTheme(theme);
            }, 300);
        };
    </script>
</body>
</html>
